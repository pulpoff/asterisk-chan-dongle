# Asterisk + chan_dongle GSM/IAX2 Gateway — Environment Configuration
# Copy this file to .env and fill in your IAX2 credentials:
#   cp docker/.env.example .env

# Required: IAX2 account credentials and PBX host
IAX_USER=your_username
IAX_PASS=your_password
IAX_HOST=pbx.example.com

# Optional (defaults shown)
IAX_PORT=4569
DONGLE_CONTEXT=from-dongle
