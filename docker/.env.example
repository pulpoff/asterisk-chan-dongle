# Asterisk + chan_dongle GSM Gateway — Environment Configuration
# Copy this file to .env and fill in your credentials:
#   cp docker/.env.example .env

# Trunk protocol: iax, sip, or pjsip
TRUNK_PROTO=iax

# Required: trunk account credentials and PBX host
TRUNK_USER=your_username
TRUNK_PASS=your_password
TRUNK_HOST=pbx.example.com

# Optional: port (defaults to 4569 for IAX, 5060 for SIP/PJSIP)
# TRUNK_PORT=4569

# Optional: Asterisk context for inbound calls from trunk
DONGLE_CONTEXT=from-dongle

# ── Custom config overrides ──────────────────────────────────────────────
# To override any generated Asterisk config, uncomment the volume mount in
# docker-compose.yml and drop .conf files into a ./configs/ directory:
#
#   mkdir configs
#   docker compose up -d          # start once so configs are generated
#   docker compose cp asterisk-dongle:/etc/asterisk/dongle.conf configs/
#   # edit configs/dongle.conf as needed
#   docker compose restart
#
# Any .conf file in ./configs/ replaces the generated version.
